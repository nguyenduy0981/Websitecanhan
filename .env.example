# VÔ TRI — required environment variables for the Supabase backend.
# Copy to .env.local (already gitignored) and fill in real values once a
# Supabase project exists. See docs/BACKEND_ARCHITECTURE.md §11 for how
# to obtain each one — all three come from the project's own Settings →
# API page on supabase.com.

# Safe to expose to the browser (NEXT_PUBLIC_* is bundled into client JS).
# Identifies which Supabase project to talk to.
NEXT_PUBLIC_SUPABASE_URL=

# Safe to expose to the browser. Authorization is enforced by Row Level
# Security on every table, not by keeping this secret — see
# docs/BACKEND_ARCHITECTURE.md §6.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NEVER expose this to the browser and NEVER prefix it with NEXT_PUBLIC_.
# Bypasses Row Level Security entirely. Only read by
# src/vo-tri/server/supabase/admin-client.ts, which must only be imported
# from server-only code paths (scheduled jobs, never a request handler
# that echoes client input straight through).
SUPABASE_SERVICE_ROLE_KEY=
