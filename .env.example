# Copy to .env and fill in real values. Never commit .env.
# All variables here are validated at startup in src/env.ts.

# --- Required ---

# Neon Postgres connection string. Get it from the Neon dashboard
# (Connection Details -> Pooled connection recommended for serverless).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random secret used to sign/encrypt session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET="replace-with-a-random-64-char-hex-string-min-32-chars"

# Shared secret required in the Authorization header of every Vercel Cron
# request, so background job routes can't be triggered by outsiders. Generate with:
#   openssl rand -hex 16
CRON_SECRET="replace-with-a-random-secret-min-16-chars"

# Public base URL of the deployed app (no trailing slash). Used to build
# share links, QR codes, and password-reset email links.
# Optional on Vercel — if unset, it's auto-derived from Vercel's own
# VERCEL_PROJECT_PRODUCTION_URL/VERCEL_URL env vars, so it can never
# silently point at localhost in production. Set this explicitly if you
# have a real custom domain (e.g. https://lovebox.vn).
APP_URL="http://localhost:3000"

# --- Optional: Cloudflare R2 (media storage, S3-compatible API) ---
# Create a bucket + API token in the Cloudflare dashboard (R2 > Manage API tokens).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# --- Optional: Resend (transactional email) ---
# Get an API key at https://resend.com/api-keys, verify a sending domain first.
RESEND_API_KEY=""
EMAIL_FROM=""

# --- Optional: PayOS (VietQR bank-transfer payments) ---
# Obtain from the PayOS merchant dashboard.
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""

# --- Optional: business config overrides ---
VIP_PRICE_VND="49000"
RECOVERY_DURATION_DAYS="7"

# --- Optional: first-admin bootstrap ---
# The account with this email is auto-promoted to SUPER_ADMIN on its next
# register/login — the only way to get an admin role without direct DB
# access (owner is phone-only). Self-healing: even if that account is
# later demoted, it's re-promoted on its next login. Leave unset once
# you no longer need to bootstrap a new admin.
SUPER_ADMIN_EMAIL=""
